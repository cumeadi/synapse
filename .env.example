# ──────────────────────────────────────────────
# Synapse — Environment Variables
# ──────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse_secret
POSTGRES_DB=synapse
DATABASE_URL=postgresql+asyncpg://synapse:synapse_secret@localhost:5433/synapse

# LLM (via litellm)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Models
LLM_MODEL=anthropic/claude-sonnet-4-20250514
EMBEDDING_MODEL=text-embedding-3-small

# Auth
SYNAPSE_MASTER_KEY=change-me-to-a-secure-random-string
